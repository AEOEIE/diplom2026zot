            {
                <option value="@role.Id">
                    @role.Name
                </option>
            }

        </select>

        <select class="filter-select"
                @bind="selectedStatus">

            <option value="all">
                Все
            </option>

            <option value="active">
                Активные
            </option>

            <option value="inactive">
                Неактивные
            </option>

        </select>


@code {

    private List<UserDto> users = new();

    private List<RoleDto> roles = new();

    private List<PostOfficeDto> offices = new();

    private string searchText = "";

    private string selectedRole = "all";

    private string selectedStatus = "all";

    private bool showModal;

    private bool isEdit;

    private int editingId;

    private UpdateEmployeeRequest model = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        users = await Http
            .GetFromJsonAsync<List<UserDto>>(
                "api/Users")
            ?? new();

        roles = await Http
            .GetFromJsonAsync<List<RoleDto>>(
                "api/Roles") 
            ?? new();

        offices = await Http
            .GetFromJsonAsync<List<PostOfficeDto>>(
                "api/PostOffices")
            ?? new();
    }

    private List<UserDto> FilteredUsers =>
        users
            .Where(x =>

                (
                    string.IsNullOrWhiteSpace(searchText)

                    ||

                    $"{x.LastName} {x.FirstName}"
                        .Contains(
                            searchText,
                            StringComparison.OrdinalIgnoreCase)

                    ||

                    x.Login.Contains(
                        searchText,
                        StringComparison.OrdinalIgnoreCase)
                )

                &&

                (
                    selectedRole == "all"

                    ||

                    x.RoleId.ToString()
                        == selectedRole
                )

                &&

                (
                    selectedStatus == "all"

                    ||

                    (
                        selectedStatus == "active"
                        && x.IsActive
                    )

                    ||

                    (
                        selectedStatus == "inactive"
                        && !x.IsActive
                    )
                )

            )
            .ToList();

    private void OpenCreate()
    {
        model = new UpdateEmployeeRequest
        {
            IsActive = true
        };

        isEdit = false;

        showModal = true;
    }

    private void OpenEdit(UserDto item)
    {
        editingId = item.Id;

        model = new UpdateEmployeeRequest
        {
            FirstName = item.FirstName,
            LastName = item.LastName,
            MiddleName = item.MiddleName,

            Phone = item.Phone,
            Email = item.Email,
            Login = item.Login,

            RoleId = item.RoleId,

            PostOfficeId = item.PostOfficeId,

            IsActive = item.IsActive
        };

        isEdit = true;

        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task Save()
    {
        if (isEdit)
        {
            await Http.PutAsJsonAsync(
                $"api/Users/{editingId}",
                model);
        }
        else
        {
            await Http.PostAsJsonAsync(
                "api/Users/employee",
                model);
        }

        await LoadData();

        showModal = false;
    }

} *@
@page "/users"

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using NewDiplom.Client.DTOs
@using NewDiplom.Client.DTOs.Users
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms

@inject HttpClient Http
@inject AuthenticationStateProvider AuthProvider

<div class="page">

    <div class="top-panel">

        <input class="search-input"
               placeholder="Поиск пользователя..."
               @bind="searchText"
               @bind:event="oninput" />

        <select class="filter-select"
                @bind="selectedRole">

            <option value="all">
                Все роли
            </option>

            @foreach (var role in roles)
            {
                <option value="@role.Id">
                    @role.Name
                </option>
            }

        </select>

        <select class="filter-select"
                @bind="selectedStatus">

            <option value="all">
                Все
            </option>

            <option value="active">
                Активные
            </option>

            <option value="inactive">
                Неактивные
            </option>

        </select>

        <button class="add-button"
                @onclick="OpenCreate">

            + Добавить

        </button>

    </div>

    @if (FilteredUsers.Count == 0)
    {
        <div class="empty-block">
            Пользователи не найдены
        </div>
    }
    else
    {
        <div class="cards-container">

            @foreach (var item in FilteredUsers)
            {
                <div class="service-card">

                    <div class="service-header">

                        <div class="service-name">
                            @item.LastName
                            @item.FirstName
                        </div>

                        <div class="service-price">
                            @item.Role
                        </div>

                    </div>

                    <div class="service-description">

                        <div>
                            Логин: @item.Login
                        </div>

                        <div>
                            Телефон: @item.Phone
                        </div>

                        <div>
                            Email: @item.Email
                        </div>

                        @if (!string.IsNullOrWhiteSpace(
                                                item.PostOfficeName))
                        {
                            <div>
                                Отделение:
                                @item.PostOfficeName
                            </div>
                        }

                    </div>
                    <div class="service-status @(item.IsActive ? "active" : "inactive")">

                        @(item.IsActive
                                                ? "Активен"
                                                : "Неактивен")

                    </div>

                    <button class="edit-button"
                            @onclick="() => OpenEdit(item)">

                        Редактировать

                    </button>

                </div>
            }

        </div>
    }

</div>

@if (showModal)
{
    <div class="modal-background"
         @onclick="CloseModal">

        <div class="modal-window"
             @onclick:stopPropagation="true">

            <h2 class="modal-title">

                @(isEdit
                                ? "Редактирование пользователя"
                                : "Добавление пользователя")

            </h2>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="error-message">
                    @errorMessage
                </div>
            }

            <EditForm Model="model"
                      OnValidSubmit="Save">

                <DataAnnotationsValidator />

                <ValidationSummary />

                <div class="form-grid">

                    <div class="form-group">

                        <label>
                            Фамилия
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.LastName" />

                        <ValidationMessage For="@(() => model.LastName)" />

                    </div>

                    <div class="form-group">

                        <label>
                            Имя
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.FirstName" />

                        <ValidationMessage For="@(() => model.FirstName)" />

                    </div>

                    <div class="form-group">

                        <label>
                            Отчество
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.MiddleName" />

                    </div>

                    <div class="form-group">

                        <label>
                            Телефон
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.Phone" />

                        <ValidationMessage For="@(() => model.Phone)" />

                    </div>

                    <div class="form-group">

                        <label>
                            Email
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.Email" />

                        <ValidationMessage For="@(() => model.Email)" />

                    </div>

                    <div class="form-group">

                        <label>
                            Логин
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.Login" />

                        <ValidationMessage For="@(() => model.Login)" />

                    </div>

                    <div class="form-group">

                        <label>
                            Пароль
                        </label>

                        <InputText type="password"
                                   class="form-input"
                                   @bind-Value="model.Password" />

                        <ValidationMessage For="@(() => model.Password)" />

                    </div>
                    <div class="form-group">

                        <label>
                            Серия паспорта
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.PassportSeries" />

                        <ValidationMessage For="@(() => model.PassportSeries)" />

                    </div>

                    <div class="form-group">

                        <label>
                            Номер паспорта
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.PassportNumber" />

                        <ValidationMessage For="@(() => model.PassportNumber)" />

                    </div>

                    <div class="form-group">

                        <label>
                            Кем выдан
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.PassportIssuedBy" />

                        <ValidationMessage For="@(() => model.PassportIssuedBy)" />

                    </div>

                    <div class="form-group">

                        <label>
                            Дата выдачи
                        </label>

                        <InputDate class="form-input"
                                   @bind-Value="model.PassportIssueDate" />

                        <ValidationMessage For="@(() => model.PassportIssueDate)" />

                    </div>

                    <div class="form-group full-width">

                        <label>
                            Адрес регистрации
                        </label>

                        <InputText class="form-input"
                                   @bind-Value="model.RegistrationAddress" />

                        <ValidationMessage For="@(() => model.RegistrationAddress)" />

                    </div>

                    <div class="form-group">

                        <label>
                            Роль
                        </label>

                        <select class="form-input"
                                @bind="model.RoleId">

                            @foreach (var role in roles)
                            {
                                <option value="@role.Id">
                                    @role.Name
                                </option>
                            }

                        </select>

                    </div>

                    <div class="form-group">

                        <label>
                            Отделение
                        </label>

                        <select class="form-input"
                                @bind="model.PostOfficeId">

                            <option value="">
                                Нет
                            </option>

                            @foreach (var office in offices)
                            {
                                <option value="@office.Id">
                                    @office.Name
                                </option>
                            }

                        </select>

                    </div>

                </div>

                @if (isEdit)
                {
                    <div class="checkbox-group">

                        <InputCheckbox @bind-Value="model.IsActive" />

                        <span>
                            Активен
                        </span>

                    </div>
                }

                <div class="buttons-row">

                    <button type="button"
                            class="cancel-button"
                            @onclick="CloseModal">

                        Отмена

                    </button>

                    <button type="submit"
                            class="save-button">

                        Сохранить

                    </button>

                </div>

            </EditForm>

        </div>

    </div>
}

@code {

    private List<UserDto> users = new();

    private List<RoleDto> roles = new();

    private List<PostOfficeDto> offices = new();

    private string searchText = "";

    private string selectedRole = "all";

    private string selectedStatus = "all";

    private bool showModal;

    private bool isEdit;

    private int editingId;

    private string? errorMessage;

    private UpdateEmployeeRequest model = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        users = await Http
            .GetFromJsonAsync<List<UserDto>>(
                "api/Users")
            ?? new();

        roles = await Http
            .GetFromJsonAsync<List<RoleDto>>(
                "api/Roles")
            ?? new();

        offices = await Http
            .GetFromJsonAsync<List<PostOfficeDto>>(
                "api/PostOffices")
            ?? new();
    }

    private List<UserDto> FilteredUsers =>
        users
            .Where(x =>

                (
                    string.IsNullOrWhiteSpace(searchText)

                    ||

                    $"{x.LastName} {x.FirstName}"
                        .Contains(
                            searchText,
                            StringComparison.OrdinalIgnoreCase)

                    ||

                    x.Login.Contains(
                        searchText,
                        StringComparison.OrdinalIgnoreCase)
                )

                &&

                (
                    selectedRole == "all"

                    ||

                    x.RoleId.ToString()
                        == selectedRole
                )

                &&

                (
                    selectedStatus == "all"

                    ||

                    (
                        selectedStatus == "active"
                        && x.IsActive
                    )

                    ||

                    (
                        selectedStatus == "inactive"
                        && !x.IsActive
                    )
                )

            )
            .ToList();

    private void OpenCreate()
    {
        errorMessage = null;

        model = new UpdateEmployeeRequest
        {
            IsActive = true
        };

        isEdit = false;

        showModal = true;
    }

    private void OpenEdit(UserDto item)
    {
        errorMessage = null;

        editingId = item.Id;

        model = new UpdateEmployeeRequest
        {
            FirstName = item.FirstName,
            LastName = item.LastName,
            MiddleName = item.MiddleName,

            Phone = item.Phone,
            Email = item.Email,
            Login = item.Login,

            PassportSeries = item.PassportSeries,
            PassportNumber = item.PassportNumber,
            PassportIssuedBy = item.PassportIssuedBy,
            PassportIssueDate = item.PassportIssueDate,

            RegistrationAddress = item.RegistrationAddress,


            RoleId = item.RoleId,

            PostOfficeId = item.PostOfficeId,

            IsActive = item.IsActive
        };

        isEdit = true;

        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task Save()
    {
        errorMessage = null;

        HttpResponseMessage response;

        if (isEdit)
        {
            response = await Http.PutAsJsonAsync(
                $"api/Users/{editingId}",
                model);
        }
        else
        {
            response = await Http.PostAsJsonAsync(
                "api/Users/employee",
                model);
        }

        if (!response.IsSuccessStatusCode)
        {
            errorMessage =
                await response.Content.ReadAsStringAsync();

            return;
        }

        await LoadData();

        showModal = false;
    }

}
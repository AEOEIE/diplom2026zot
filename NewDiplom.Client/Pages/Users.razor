                </div>

                <div class="form-group">

                    <label>
                        Телефон
                    </label>

                    <input class="form-input"
                           @bind="model.Phone" />

                </div>

                <div class="form-group">

                    <label>
                        Email
                    </label>

                    <input class="form-input"

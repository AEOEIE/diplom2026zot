
@page "/login"

@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using NewDiplom.Client.DTOs.Auth
@using NewDiplom.Client.Services

@inject HttpClient Http
@inject AuthStateProvider AuthProvider
@inject NavigationManager Navigation

<div class="auth-wrapper">

    <div class="auth-card">

        <h1 class="title">
            Почтовое отделение
        </h1>       

        <div class="switch-block">

            <span class="@(!isRegister ? "active-label" : "")">
                Вход
            </span>

            <div class="switch"
                 @onclick="ToggleMode">

                <div class="switch-circle @(isRegister ? "right" : "")">
                </div>

            </div>

            <span class="@(isRegister ? "active-label" : "")">
                Регистрация
            </span>

        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error-message">
                @errorMessage
                @if (remainingMinutes > 0 && isLocked)
                {
                    <div class="lockout-info">
                        ⏳ Разблокировка через: @remainingMinutes мин. @remainingSeconds сек.
                    </div>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="success-message">
                @successMessage
            </div>
        }

        @if (!isRegister)
        {
            <EditForm Model="loginModel"
                      OnValidSubmit="HandleLogin">

                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">

                    <label>
                        Логин
                    </label>

                    <InputText class="form-input"
                               @bind-Value="loginModel.Login"
                               disabled="@isLocked" />

                    <ValidationMessage For="@(() => loginModel.Login)" />

                </div>

                <div class="form-group">

                    <label>
                        Пароль
                    </label>

                    <InputText type="password"
                               class="form-input"
                               @bind-Value="loginModel.Password"
                               disabled="@isLocked" />

                    <ValidationMessage For="@(() => loginModel.Password)" />

                </div>

                <button class="main-button"
                        type="submit"
                        disabled="@isLocked">
                    @if (isLocked)
                    {
                        <span>⏳ Блокировка...</span>
                    }
                    else
                    {
                        <span>Войти</span>
                    }
                </button>

            </EditForm>
        }
        else
        {
            <EditForm Model="registerModel"
                      OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">

                    <label>
                        Логин
                    </label>

                    <InputText class="form-input"
                               @bind-Value="registerModel.Login" />
                    <ValidationMessage For="@(() => registerModel.Login)" />

                </div>

                <div class="form-group">

                    <label>
                        Email
                    </label>

                    <InputText class="form-input"
                               @bind-Value="registerModel.Email" />
                    <ValidationMessage For="@(() => registerModel.Email)" />

                </div>

                <div class="form-group">

                    <label>
                        Пароль
                    </label>

                    <InputText type="password"
                               class="form-input"
                               @bind-Value="registerModel.Password" />
                    <ValidationMessage For="@(() => registerModel.Password)" />

                </div>

                <button class="main-button"
                        type="submit">
                    Зарегистрироваться
                </button>

            </EditForm>
        }

    </div>

</div>

@code {

    private bool isRegister;
    private string? errorMessage;
    private string? successMessage;
    private bool isLocked = false;
    private int remainingMinutes = 0;
    private int remainingSeconds = 0;
    private System.Timers.Timer? timer;

    private LoginRequest loginModel = new();
    private RegisterRequest registerModel = new();

    private void ToggleMode()
    {
        if (isLocked) return; // Не даем переключаться во время блокировки

        isRegister = !isRegister;
        errorMessage = null;
        successMessage = null;
    }

    private async Task HandleLogin()
    {
        if (isLocked) return;

        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync(
                "api/Auth/login",
                loginModel);

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();

                if (error?.IsLocked == true)
                {
                    // Блокировка!
                    isLocked = true;
                    remainingMinutes = error.RemainingMinutes ?? LOCKOUT_MINUTES;
                    remainingSeconds = 0;
                    errorMessage = error.Message;

                    // Запускаем таймер
                    StartLockoutTimer();
                }
                else if (error?.RemainingAttempts > 0)
                {
                    // Показать сколько осталось попыток
                    errorMessage = error.Message;
                }
                else
                {
                    errorMessage = error?.Message ?? "Неверный логин или пароль";
                }
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<AuthResponse>();

            if (result == null)
            {
                errorMessage = "Ошибка сервера";
                return;
            }

            await AuthProvider.MarkUserAsAuthenticated(result.Token);
            if(result.Role == "Client")
            {
                Navigation.NavigateTo("/my-shipments", true);
            }
            else if (result.Role == "ServiceManager")
            {
                Navigation.NavigateTo("/services", true);
            }
            else
            {
                Navigation.NavigateTo("/shipments", true);
            }
            
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
    }

    private void StartLockoutTimer()
    {
        timer?.Dispose();
        timer = new System.Timers.Timer(1000);
        timer.Elapsed += (sender, e) =>
        {
            if (remainingMinutes == 0 && remainingSeconds == 0)
            {
                timer.Stop();
                isLocked = false;
                errorMessage = "";
                remainingMinutes = 0;
                remainingSeconds = 0;
                InvokeAsync(StateHasChanged);
            }
            else if (remainingSeconds == 0)
            {
                remainingMinutes--;
                remainingSeconds = 59;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                remainingSeconds--;
                InvokeAsync(StateHasChanged);
            }
        };
        timer.Start();
    }

    private async Task HandleRegister()
    {
        errorMessage = null;

        var response = await Http.PostAsJsonAsync(
            "api/Auth/register",
            registerModel);

        if (!response.IsSuccessStatusCode)
        {
            errorMessage = "Этот логин или email уже используется";
            return;
        }

        successMessage = "Регистрация успешна";

        await Task.Delay(1000);

        isRegister = false;
    }

    // Константа для доступа в таймере
    private const int LOCKOUT_MINUTES = 5;

    // Класс для обработки ошибок
    private class ErrorResponse
    {
        public string? Message { get; set; }
        public int? RemainingMinutes { get; set; }
        public int? RemainingAttempts { get; set; }
        public bool IsLocked { get; set; }
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}
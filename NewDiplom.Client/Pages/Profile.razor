@page "/profile"

@using System.Net.Http.Json
@using NewDiplom.Client.DTOs.Users

@inject HttpClient Http

<PageTitle>Профиль</PageTitle>

<div class="page-container">

    <div class="page-card">

        <h1 class="page-title">
            Профиль
        </h1>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="success-message">
                @successMessage
            </div>
        }

        <EditForm Model="model"
                  OnValidSubmit="Save">

            <div class="section-title">
                Личные данные
            </div>

            <div class="form-grid">

                <div class="form-group">
                    <label>Фамилия</label>

                    <InputText class="form-input"
                               @bind-Value="model.LastName" />
                </div>

                <div class="form-group">
                    <label>Имя</label>

                    <InputText class="form-input"
                               @bind-Value="model.FirstName" />
                </div>

                <div class="form-group">
                    <label>Отчество</label>

                    <InputText class="form-input"
                               @bind-Value="model.MiddleName" />
                </div>

                <div class="form-group">
                    <label>Телефон</label>

                    <InputText class="form-input"
                               @bind-Value="model.Phone" />
                </div>

                <div class="form-group">
                    <label>Email</label>

                    <InputText class="form-input"
                               @bind-Value="model.Email" />
                </div>

            </div>

            <div class="section-title">
                Паспорт
            </div>

            <div class="form-grid">

                <div class="form-group">
                    <label>Серия</label>

                    <InputText class="form-input"
                               @bind-Value="model.PassportSeries" />
                </div>

                <div class="form-group">
                    <label>Номер</label>

                    <InputText class="form-input"
                               @bind-Value="model.PassportNumber" />
                </div>

                <div class="form-group">
                    <label>Кем выдан</label>

                    <InputText class="form-input"
                               @bind-Value="model.PassportIssuedBy" />
                </div>

                <div class="form-group">
                    <label>Дата выдачи</label>

                    <InputDate class="form-input"
                               @bind-Value="model.PassportIssueDate" />
                </div>

            </div>

            <div class="form-group">
                <label>Адрес регистрации</label>

                <InputText class="form-input"
                           @bind-Value="model.RegistrationAddress" />
            </div>

            <button class="main-button"
                    type="submit">
                Сохранить
            </button>

        </EditForm>

    </div>

</div>

@code {

    private UpdateProfileRequest model = new();

    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        var user = await Http
            .GetFromJsonAsync<UserDto>("api/Users/me");

        model.FirstName = user!.FirstName;
        model.LastName = user.LastName;
        model.Phone = user.Phone;
        model.Email = user.Email;
        model.MiddleName = user.MiddleName;

        model.PassportSeries = user.PassportSeries;
        model.PassportNumber = user.PassportNumber;
        model.PassportIssuedBy = user.PassportIssuedBy;
        model.PassportIssueDate = user.PassportIssueDate;
        model.RegistrationAddress = user.RegistrationAddress;
    }

    private async Task Save()
    {
        var response = await Http.PutAsJsonAsync(
            "api/Users/me",
            model);

        if (response.IsSuccessStatusCode)
        {
            successMessage = "Профиль сохранён";
        }
    }

}
@page "/create-shipment"

@using NewDiplom.Client.DTOs
@using NewDiplom.Client.DTOs.Shipments
@using NewDiplom.Client.DTOs.Users

@inject HttpClient Http

<div class="page">

    <div class="page-card">

        <h2 class="modal-title" style="text-align: center; margin-bottom: 30px;">
            Создание отправления
        </h2>

        @if (!profileCompleted)
        {
            <div style="background: #fff3e0; color: #e65100; padding: 15px; border-radius: 14px; margin-bottom: 20px; font-weight: 500;">
                ⚠️ Для создания отправления заполните профиль в личном кабинете
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div style="background: #e8f5e9; color: #2e7d32; padding: 15px; border-radius: 14px; margin-bottom: 20px; font-weight: 500;">
                ✅ @successMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div style="background: #fce4ec; color: #c62828; padding: 15px; border-radius: 14px; margin-bottom: 20px; font-weight: 500;">
                ❌ @errorMessage
            </div>
        }

        <div class="form-grid">

            <div class="form-group">
                <label>Получатель *</label>
                <input class="form-input"
                       @bind="model.RecipientName"
                       placeholder="ФИО получателя"
                       disabled="@(!profileCompleted)" />
            </div>

            <div class="form-group">
                <label>Телефон получателя *</label>
                <input class="form-input"
                       @bind="model.RecipientPhone"
                       placeholder="+7 (___) ___-__-__"
                       disabled="@(!profileCompleted)" />
            </div>

            <div class="form-group">
                <label>Отделение отправления *</label>
                <select class="form-input"
                        @bind="model.CurrentOfficeId"
                        disabled="@(!profileCompleted)">
                    <option value="0">Выберите отделение</option>
                    @foreach (var office in offices)
                    {
                        <option value="@office.Id">
                            @office.Code - @office.Name
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Отделение назначения *</label>
                <select class="form-input"
                        @bind="selectedDestinationOfficeId"
                        @bind:after="OnDestinationOfficeSelected"
                        disabled="@(!profileCompleted)">
                    <option value="">Выберите отделение</option>
                    @foreach (var office in offices)
                    {
                        <option value="@office.Id">
                            @office.Code - @office.Address
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Адрес доставки</label>
                <input class="form-input"
                       @bind="model.DestinationAddress"
                       placeholder="Выберите отделение назначения"
                       disabled="@(!profileCompleted)" />
            </div>

            <div class="form-group">
                <label>Тип услуги *</label>
                <select class="form-input"
                        @bind="model.ServiceTypeId"
                        disabled="@(!profileCompleted)">
                    <option value="0">Выберите тип</option>
                    @foreach (var service in services)
                    {
                        <option value="@service.Id">
                            @service.Name - @service.BasePrice.ToString("C")
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Способ доставки *</label>
                <select class="form-input"
                        @bind="model.DeliveryMethodId"
                        disabled="@(!profileCompleted)">
                    <option value="0">Выберите способ</option>
                    @foreach (var method in methods)
                    {
                        <option value="@method.Id">
                            @method.Name (+@method.AdditionalPrice.ToString("C"))
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Вес (кг) *</label>
                <input type="number"
                       step="0.01"
                       min="0.01"
                       class="form-input"
                       @bind="model.WeightKg"
                       placeholder="0.00"
                       disabled="@(!profileCompleted)" />
            </div>

            <div class="form-group">
                <label>Объявленная ценность (₽)</label>
                <input type="number"
                       step="0.01"
                       min="0"
                       class="form-input"
                       @bind="model.DeclaredValue"
                       placeholder="0.00"
                       disabled="@(!profileCompleted)" />
            </div>

        </div>

        <div class="form-group" style="margin-top: 18px;">
            <label>Примечания</label>
            <textarea class="form-input"
                      @bind="model.Notes"
                      rows="3"
                      placeholder="Дополнительная информация..."
                      disabled="@(!profileCompleted)"></textarea>
        </div>

        <div class="buttons-row" style="margin-top: 24px;">
            <button class="save-button"
                    disabled="@(!profileCompleted)"
                    @onclick="CreateShipment1">
                Создать отправление
            </button>
        </div>

    </div>

</div>

@code {

    private CreateShipmentRequest model = new();
    private List<PostOfficeDto> offices = new();
    private List<ServiceTypeDto> services = new();
    private List<DeliveryMethodDto> methods = new();
    private int? selectedDestinationOfficeId;

    private bool profileCompleted;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = await Http.GetFromJsonAsync<UserDto>("api/Users/me");
            profileCompleted = user?.IsProfileCompleted ?? false;

            offices = await Http.GetFromJsonAsync<List<PostOfficeDto>>("api/PostOffices") ?? new();
            services = await Http.GetFromJsonAsync<List<ServiceTypeDto>>("api/ServiceTypes") ?? new();
            methods = await Http.GetFromJsonAsync<List<DeliveryMethodDto>>("api/DeliveryMethods") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private void OnDestinationOfficeSelected()
    {
        if (selectedDestinationOfficeId.HasValue)
        {
            var office = offices.FirstOrDefault(o => o.Id == selectedDestinationOfficeId.Value);
            if (office != null)
            {
                model.DestinationAddress = office.Address;
                model.DestinationOfficeId = office.Id;
            }
        }
    }

    private async Task CreateShipment1()
    {
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrWhiteSpace(model.RecipientName))
        {
            errorMessage = "Укажите получателя";
            return;
        }

        if (string.IsNullOrWhiteSpace(model.RecipientPhone))
        {
            errorMessage = "Укажите телефон получателя";
            return;
        }

        if (model.CurrentOfficeId == 0)
        {
            errorMessage = "Выберите отделение отправления";
            return;
        }

        if (model.DestinationOfficeId == 0)
        {
            errorMessage = "Выберите отделение назначения";
            return;
        }

        if (model.CurrentOfficeId == model.DestinationOfficeId)
        {
            errorMessage = "Отделение отправления и назначения не могут совпадать";
            return;
        }

        if (model.ServiceTypeId == 0)
        {
            errorMessage = "Выберите тип услуги";
            return;
        }

        if (model.DeliveryMethodId == 0)
        {
            errorMessage = "Выберите способ доставки";
            return;
        }

        if (model.WeightKg <= 0)
        {
            errorMessage = "Укажите вес отправления";
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/Shipments", model);

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Отправление успешно создано!";
                model = new CreateShipmentRequest();
                selectedDestinationOfficeId = null;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Ошибка: {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
    }

}
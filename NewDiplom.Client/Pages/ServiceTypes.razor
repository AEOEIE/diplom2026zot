@page "/services"

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using NewDiplom.Client.DTOs

@inject HttpClient Http
@inject AuthenticationStateProvider AuthProvider

<div class="page">

    <div class="top-panel">

        <input class="search-input"
               placeholder="Поиск услуги..."
               @bind="searchText"
               @bind:event="oninput" />

        <select class="filter-select"
                @bind="selectedFilter">

            <option value="all">
                Все
            </option>

            <option value="active">
                Активные
            </option>

            <option value="inactive">
                Неактивные
            </option>

        </select>

        @if (!isReadOnly)
        {
            <button class="add-button"
                    @onclick="OpenCreate">
                + Добавить
            </button>
        }

    </div>

    @if (FilteredServices.Count == 0)
    {
        <div class="empty-block">
            Ничего не найдено
        </div>
    }
    else
    {
        <div class="cards-container">

            @foreach (var item in FilteredServices)
            {
                <div class="service-card">

                    <div class="service-header">

                        <div class="service-name">
                            @item.Name
                        </div>

                        <div class="service-price">
                            @item.BasePrice ₽
                        </div>

                    </div>

                    <div class="service-description">
                        @item.Description
                    </div>

                    <div class="service-status @(item.IsActive ? "active" : "inactive")">

                        @(item.IsActive
                                        ? "Активна"
                                        : "Неактивна")

            </div>

            @if (!isReadOnly)
                    {
                        <button class="edit-button"
                                @onclick="() => OpenEdit(item)">
                            Редактировать
                        </button>
                    }

                </div>
            }

        </div>
    }

</div>

@if (showModal)
{
    <div class="modal-background"
         @onclick="CloseModal">

        <div class="modal-window"
             @onclick:stopPropagation="true">

            <h2 class="modal-title">
                @(isEdit
                            ? "Редактирование услуги"
                            : "Добавление услуги")
        </h2>

            <div class="form-group">

                <label>
                    Название
                </label>

                <input class="form-input"
                       @bind="model.Name" />

            </div>

            <div class="form-group">

                <label>
                    Цена
                </label>

                <input type="number"
                       class="form-input"
                       @bind="model.BasePrice" />

            </div>

            <div class="form-group">

                <label>
                    Описание
                </label>

                <textarea class="form-input textarea"
                          @bind="model.Description">
                    </textarea>

            </div>

        @if (isEdit)
            {
                <div class="checkbox-group">

                    <InputCheckbox @bind-Value="editIsActive" />

                    <span>
                        Активна
                    </span>

                </div>
            }

            <div class="buttons-row">

                <button class="cancel-button"
                        @onclick="CloseModal">
                    Отмена
                </button>

                <button class="save-button"
                        @onclick="Save">
                    Сохранить
                </button>

            </div>

        </div>

    </div>
}

@code {

    private List<ServiceTypeDto> services = new();

    private string searchText = "";

    private string selectedFilter = "all";

    private bool showModal;

    private bool isEdit;

    private bool isReadOnly;

    private bool editIsActive = true;

    private int editingId;

    private CreateServiceTypeDto model = new();

    protected override async Task OnInitializedAsync()
    {
        services = await Http
            .GetFromJsonAsync<List<ServiceTypeDto>>(
                "api/ServiceTypes")
            ?? new();

        var authState =
            await AuthProvider
                .GetAuthenticationStateAsync();

        var user = authState.User;

        var role = user.FindFirst(
            ClaimTypes.Role)?.Value;

        isReadOnly =
            role == "DepartmentHead" || role == "Operator";
    }

    private List<ServiceTypeDto> FilteredServices =>
        services
            .Where(x =>

                (string.IsNullOrWhiteSpace(searchText)
                 || x.Name.Contains(
                     searchText,
                     StringComparison.OrdinalIgnoreCase))

                &&

                (selectedFilter == "all"
                 || (selectedFilter == "active"
                     && x.IsActive)
                 || (selectedFilter == "inactive"
                     && !x.IsActive))

            )
            .ToList();

    private void OpenCreate()
    {
        model = new CreateServiceTypeDto();

        editIsActive = true;

        isEdit = false;

        showModal = true;
    }

    private void OpenEdit(ServiceTypeDto item)
    {
        editingId = item.Id;

        model = new CreateServiceTypeDto
        {
            Name = item.Name,
            BasePrice = item.BasePrice,
            Description = item.Description
        };

        editIsActive = item.IsActive;

        isEdit = true;

        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task Save()
    {
        if (isEdit)
        {
            var update =
                new UpdateServiceTypeDto
                {
                    Name = model.Name,
                    BasePrice = model.BasePrice,
                    Description = model.Description,
                    IsActive = editIsActive
                };

            await Http.PutAsJsonAsync(
                $"api/ServiceTypes/{editingId}",
                update);
        }
        else
        {
            await Http.PostAsJsonAsync(
                "api/ServiceTypes",
                model);
        }

        services = await Http
            .GetFromJsonAsync<List<ServiceTypeDto>>(
                "api/ServiceTypes")
            ?? new();

        showModal = false;
    }

}